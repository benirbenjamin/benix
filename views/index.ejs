      // Extract categories and populate filter
      originalProducts.forEach(product => {
        if (product.category) {
          productCategories.add(product.category);
        }
      });

      const categorySelect = document.getElementById('productCategoryFilter');
      if (categorySelect) {
        productCategories.forEach(category => {
          const option = document.createElement('option');
          option.value = category;
          option.textContent = category;
          categorySelect.appendChild(option);
        });
      }

      // Initially display all products
      displayProducts(originalProducts);
      
      // Initially display all links
      displayLinks(originalLinks);
      
      // Initially display all links for logged in users too
      displayLinksLoggedIn(originalLinks);
      
      console.log('Initialization complete. Products:', originalProducts.length, 'Links:', originalLinks.length);
      
      // Add debounced search functionality
      setupSearchListeners();
    });

    // Debounce function to prevent excessive API calls
    function debounce(func, wait) {
      let timeout;
      return function executedFunction(...args) {
        const later = () => {
          clearTimeout(timeout);
          func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
      };
    }

    // Setup search event listeners - only manual search via buttons
    function setupSearchListeners() {
      // Add click handlers for search buttons only
      const productSearchBtn = document.getElementById('productSearchBtn');
      const productClearBtn = document.getElementById('productClearBtn');
      const linkSearchBtn = document.getElementById('linkSearchBtn');
      const linkClearBtn = document.getElementById('linkClearBtn');
      const linkSearchLoggedInBtn = document.getElementById('linkSearchLoggedInBtn');
      const linkClearLoggedInBtn = document.getElementById('linkClearLoggedInBtn');

      if (productSearchBtn) {
        productSearchBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          filterProducts();
        });
      }

      if (productClearBtn) {
        productClearBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          clearProductFilters();
        });
      }

      if (linkSearchBtn) {
        linkSearchBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          filterLinks();
        });
      }

      if (linkClearBtn) {
        linkClearBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          clearLinkFilters();
        });
      }

      if (linkSearchLoggedInBtn) {
        linkSearchLoggedInBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          filterLinksLoggedIn();
        });
      }

      if (linkClearLoggedInBtn) {
        linkClearLoggedInBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          clearLinkFiltersLoggedIn();
        });
      }

      // Add Enter key support for search inputs to trigger search button
      const productSearchInput = document.getElementById('productSearch');
      const linkSearchInput = document.getElementById('linkSearch');
      const linkSearchLoggedIn = document.getElementById('linkSearchLoggedIn');

      if (productSearchInput) {
        productSearchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            e.stopPropagation();
            if (productSearchBtn) productSearchBtn.click();
          }
        });
      }

      if (linkSearchInput) {
        linkSearchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            e.stopPropagation();
            if (linkSearchBtn) linkSearchBtn.click();
          }
        });
      }

      if (linkSearchLoggedIn) {
        linkSearchLoggedIn.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            e.stopPropagation();
            if (linkSearchLoggedInBtn) linkSearchLoggedInBtn.click();
          }
        });
      }

      // IMPORTANT: Prevent any automatic filtering on input/change events
      // Remove any existing event listeners that might cause auto-search
      [productSearchInput, linkSearchInput, linkSearchLoggedIn].forEach(input => {
        if (input) {
          // Remove all input event listeners to prevent auto-search
          input.addEventListener('input', (e) => {
            e.preventDefault();
            e.stopPropagation();
            // Do nothing - no auto search
          });
          
          // Prevent any change events from triggering search
          input.addEventListener('change', (e) => {
            e.preventDefault();
            e.stopPropagation();
            // Do nothing - no auto search
          });
        }
      });

      // Also prevent auto-search on dropdowns/selects
      const categoryFilter = document.getElementById('productCategoryFilter');
      const linkTypeFilter = document.getElementById('linkTypeFilter');
      const linkTypeFilterLoggedIn = document.getElementById('linkTypeFilterLoggedIn');

      [categoryFilter, linkTypeFilter, linkTypeFilterLoggedIn].forEach(select => {
        if (select) {
          select.addEventListener('change', (e) => {
            e.preventDefault();
            e.stopPropagation();
            // Do nothing - no auto search
          });
        }
      });
    }

    // Prevent any accidental form submissions that might cause page reloads
    document.addEventListener('DOMContentLoaded', function() {
      // Prevent form submissions on the entire page
      document.addEventListener('submit', function(e) {
        e.preventDefault();
        e.stopPropagation();
        console.log('Form submission prevented to maintain search state');
        return false;
      });
      
      // Prevent Enter key from causing any unwanted submissions
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && e.target.matches('input[type="text"], input[type="number"], input[type="search"]')) {
          const targetId = e.target.id;
          if (targetId && (targetId.includes('Search') || targetId.includes('Price'))) {
            e.preventDefault();
            e.stopPropagation();
            // Let the specific event handlers deal with filtering
          }
        }
      });
    });

    function filterProducts() {
      const searchTerm = document.getElementById('productSearch')?.value.toLowerCase() || '';
      const selectedCategory = document.getElementById('productCategoryFilter')?.value || 'all';
      const minPriceValue = parseFloat(document.getElementById('minPrice')?.value) || 0;
      const maxPriceValue = parseFloat(document.getElementById('maxPrice')?.value) || Infinity;

      const filteredProducts = originalProducts.filter(product => {
        const matchesSearch = !searchTerm || 
          product.name.toLowerCase().includes(searchTerm) ||
          product.description.toLowerCase().includes(searchTerm) ||
          product.merchant_name.toLowerCase().includes(searchTerm);

        const matchesCategory = selectedCategory === 'all' || product.category === selectedCategory;
        
        const matchesPrice = product.price >= minPriceValue && product.price <= maxPriceValue;

        return matchesSearch && matchesCategory && matchesPrice;
      });

      displayProducts(filteredProducts);
    }

