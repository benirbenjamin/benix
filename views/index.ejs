    function initializeYouTubeLazyLoading() {
      // Re-observe new YouTube elements
      const newYoutubeElements = document.querySelectorAll('.youtube-lazy:not([data-observed])');
      newYoutubeElements.forEach(element => {
        element.setAttribute('data-observed', 'true');
        observer.observe(element);
        
        // Add click handler for immediate loading
        element.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          
          const videoId = this.dataset.videoId;
          const videoTitle = this.dataset.videoTitle;
          
          // Check if already loaded
          const existingIframe = this.querySelector('iframe');
          if (existingIframe) {
            return;
          }
          
          loadYouTubeVideo(this, videoId, videoTitle);
          loadedVideos.add(videoId);
          observer.unobserve(this);
        });
      });
    }

    // Lazy loading for YouTube videos using Intersection Observer
    const youtubeLazyElements = document.querySelectorAll('.youtube-lazy');
    const loadedVideos = new Set();
    let allYoutubePlayers = new Map(); // Use Map for better tracking
    
    // Intersection Observer for lazy loading
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const element = entry.target;
          const videoId = element.dataset.videoId;
          const videoTitle = element.dataset.videoTitle;
          
          // Only load if not already loaded and doesn't have an iframe
          if (!loadedVideos.has(videoId) && !element.querySelector('iframe')) {
            console.log('Loading video via intersection observer:', videoId);
            loadYouTubeVideo(element, videoId, videoTitle);
            loadedVideos.add(videoId);
            observer.unobserve(element); // Stop observing this element
          }
        }
      });
    }, {
      rootMargin: '50px' // Start loading 50px before the element enters viewport
    });
    
    // Observe all YouTube lazy elements
    youtubeLazyElements.forEach(element => {
      observer.observe(element);
      
      // Add click handler for immediate loading
      element.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        const videoId = this.dataset.videoId;
        const videoTitle = this.dataset.videoTitle;
        
        console.log('YouTube video clicked - ID:', videoId, 'Title:', videoTitle);
        
        // Check if the element already has an iframe (video loaded)
        const existingIframe = this.querySelector('iframe');
        if (existingIframe) {
          console.log('Video already loaded, user can interact with it directly');
          // Don't auto-play, let the user click the play button in the video
          return;
        }
        
        // Load the video when clicked but don't auto-play
        loadYouTubeVideo(this, videoId, videoTitle);
        loadedVideos.add(videoId);
        observer.unobserve(this);
      });
    });
    
    function loadYouTubeVideo(container, videoId, title) {
      console.log('Loading YouTube video:', videoId, title);
      
      // Check if video is already loaded
      if (container.querySelector('iframe')) {
        console.log('Video already loaded, skipping');
        return;
      }
      
      // Pause all other videos first
      pauseAllOtherVideos(videoId);
      
      // Show loading spinner
      const placeholder = container.querySelector('.youtube-placeholder');
      if (placeholder) {
        placeholder.innerHTML = `
          <div class="d-flex flex-column align-items-center justify-content-center h-100">
            <div class="spinner-border text-danger mb-2" role="status">
              <span class="visually-hidden">Loading video...</span>
            </div>
            <small class="text-white">Loading ${title}...</small>
          </div>
        `;
      }
      
      // Validate video ID
      if (!videoId || videoId.length !== 11) {
        console.error('Invalid YouTube video ID:', videoId);
        container.innerHTML = `
          <div class="d-flex flex-column align-items-center justify-content-center bg-dark text-white" style="height: 200px;">
            <i class="fab fa-youtube fa-3x text-danger mb-2"></i>
            <p class="mb-0">Invalid video ID</p>
            <small class="text-muted">${title}</small>
          </div>
        `;
        return;
      }
      
      // Create iframe
      const iframe = document.createElement('iframe');
      iframe.width = '100%';
      iframe.height = '200';
      iframe.src = `https://www.youtube.com/embed/${videoId}?enablejsapi=1&modestbranding=1&rel=0&showinfo=0&autoplay=0`;
      iframe.title = title || 'YouTube Video';
      iframe.frameBorder = '0';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      iframe.loading = 'lazy';
      iframe.style.borderRadius = '8px';
      
      // Add unique ID for YouTube API
      iframe.id = `youtube-player-${videoId}-${Date.now()}`;
      
      // Add error handling
      iframe.onerror = function() {
        console.error('Failed to load YouTube iframe for video:', videoId);
        container.innerHTML = `
          <div class="d-flex flex-column align-items-center justify-content-center h-100 bg-dark text-white" style="height: 200px;">
            <i class="fab fa-youtube fa-3x text-danger mb-2"></i>
            <p class="mb-0">Unable to load video</p>
            <small class="text-muted">${title}</small>
            <button class="btn btn-sm btn-outline-light mt-2" onclick="window.open('https://youtube.com/watch?v=${videoId}', '_blank')">
              <i class="fas fa-external-link-alt me-1"></i>Watch on YouTube
            </button>
          </div>
        `;
      };
      
      // Replace placeholder with iframe
      container.innerHTML = '';
      container.appendChild(iframe);
      
      // Initialize YouTube player for better control
      iframe.onload = function() {
        console.log('YouTube iframe loaded successfully for video:', videoId);
        if (typeof YT !== 'undefined' && YT.Player) {
          setTimeout(() => {
            try {
              initializeYouTubePlayer(iframe.id, videoId, title);
            } catch (error) {
              console.warn('YouTube player initialization failed:', error);
              // Video still works, just without API controls
            }
          }, 500);
        }
      };
    }
    
    // YouTube API ready callback
    let youtubeApiReady = false;
    
    function onYouTubeIframeAPIReady() {
      youtubeApiReady = true;
      console.log('YouTube API is ready');
    }
    
    function initializeYouTubePlayer(playerId, videoId, title) {
      try {
        const playerElement = document.getElementById(playerId);
        if (!playerElement) {
          console.warn('Player element not found:', playerId);
          return;
        }
        
        const player = new YT.Player(playerId, {
          events: {
            'onReady': function(event) {
              console.log('YouTube player ready:', playerId);
              // Store the player in our global map
              allYoutubePlayers.set(playerId, event.target);
              // Don't auto-play, let user decide when to play
            },
            'onStateChange': function(event) {
              if (event.data == YT.PlayerState.PLAYING) {
                console.log('Video started playing:', playerId);
                pauseAllOtherVideos(videoId, playerId);
              }
            },
            'onError': function(event) {
              console.error('YouTube player error:', event.data, 'for video:', videoId);
              // Handle different error types
              const container = playerElement.parentElement;
              let errorMessage = 'Video unavailable';
              
              switch(event.data) {
                case 2:
                  errorMessage = 'Invalid video ID';
                  break;
                case 5:
                  errorMessage = 'Video not supported in HTML5';
                  break;
                case 100:
                  errorMessage = 'Video not found';
                  break;
                case 101:
                case 150:
                  errorMessage = 'Video not allowed to be embedded';
                  break;
              }
              
              container.innerHTML = `
                <div class="d-flex flex-column align-items-center justify-content-center bg-dark text-white" style="height: 200px;">
                  <i class="fab fa-youtube fa-3x text-danger mb-2"></i>
                  <p class="mb-0">${errorMessage}</p>
                  <small class="text-muted">${title || 'YouTube Video'}</small>
                  <button class="btn btn-sm btn-outline-light mt-2" onclick="window.open('https://youtube.com/watch?v=${videoId}', '_blank')">
                    <i class="fas fa-external-link-alt me-1"></i>Watch on YouTube
                  </button>
                </div>
              `;
            }
          }
        });
      } catch (error) {
        console.error('Error creating YouTube player:', error);
      }
    }
    
    function pauseAllOtherVideos(currentVideoId, currentPlayerId = null) {
      console.log('Pausing all other videos except:', currentVideoId, currentPlayerId);
      
      // Pause all YouTube API players
      allYoutubePlayers.forEach((player, playerId) => {
        if (playerId !== currentPlayerId) {
          try {
            if (player && typeof player.pauseVideo === 'function') {
              const playerState = player.getPlayerState();
              if (playerState === YT.PlayerState.PLAYING) {
                console.log('Pausing YouTube player:', playerId);
                player.pauseVideo();
              }
            }
          } catch (error) {
            console.log('Could not pause YouTube player:', playerId, error);
          }
        }
      });
      
      // Also pause any regular iframe videos that might not be managed by YouTube API
      document.querySelectorAll('iframe[src*="youtube.com/embed"]').forEach(iframe => {
        if (iframe.id !== currentPlayerId) {
          try {
            // Try to pause via postMessage
            iframe.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
          } catch (error) {
            console.log('Could not pause iframe via postMessage:', iframe.id);
          }
        }
      });
    }

    // Legacy function for backward compatibility
    function pauseOtherVideos(currentPlayerId) {
      pauseAllOtherVideos('', currentPlayerId);
    }

    // Initialize clipboard.js
    if (typeof ClipboardJS !== 'undefined') {
      new ClipboardJS('.copy-btn');

      // Show success message for clipboard
      document.querySelectorAll('.copy-btn').forEach(button => {
        button.addEventListener('click', () => {
          const originalContent = button.innerHTML;
          button.innerHTML = '<i class="fas fa-check"></i>';
          setTimeout(() => {
            button.innerHTML = originalContent;
          }, 2000);
        });
      });
    }
    
    // PWA Service Worker Registration
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/service-worker.js')
          .then(registration => {
            console.log('ServiceWorker registration successful with scope: ', registration.scope);
          })
          .catch(err => {
            console.log('ServiceWorker registration failed: ', err);
          });
      });
    }

    // Add installation prompt
    let deferredPrompt;
    const installButton = document.getElementById('install-app');
    
    window.addEventListener('beforeinstallprompt', (e) => {
      // Prevent Chrome 67 and earlier from automatically showing the prompt
      e.preventDefault();
      // Stash the event so it can be triggered later
      deferredPrompt = e;
      
      // Show the install button
      if (installButton) {
        installButton.style.display = 'block';
        
        installButton.addEventListener('click', () => {
          // Show the install prompt
          deferredPrompt.prompt();
          // Wait for the user to respond to the prompt
          deferredPrompt.userChoice.then((choiceResult) => {
            if (choiceResult.outcome === 'accepted') {
              console.log('User accepted the install prompt');
            } else {
              console.log('User dismissed the install prompt');
            }
            deferredPrompt = null;
            installButton.style.display = 'none';
          });
        });
      }
    });
  </script>
</body>
</html>
