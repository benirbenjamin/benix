      <% if (links && links.length > 0) { %>
        originalLinks = <%-
          JSON.stringify(links.map(link => ({
            id: link.id,
            title: link.title || '',
            description: link.description || '',
            type: link.type || 'link',
            merchant_name: link.business_name || link.merchant_name || '',
            image_url: link.image_url || '',
            url: link.url || '',
            price: link.price || '',
            clicks_count: link.clicks_count || 0,
            click_target: link.click_target || ''
          })))
        %>;
      <% } else { %>
        originalLinks = [];
