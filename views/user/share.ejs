<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Share Link - <%= link.title %> - BenixSpace</title>
  <link rel="icon" href="/favicon.png" type="image/x-icon" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="icon" href="/favicon.png" type="image/x-icon" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <meta property="og:title" content="<%= link.title %>">
  <meta property="og:description" content="<%= link.description %>">
  <% if (link.image_url) { %>
    <meta property="og:image" content="<%= link.image_url %>">
  <% } %>
  
  <style>
    /* YouTube Preview Styling */
    .youtube-preview-container {
      border-radius: 8px;
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.3s ease;
    }

    .youtube-preview-container:hover {
      transform: scale(1.01);
    }

    .youtube-placeholder {
      background: linear-gradient(135deg, #000, #333);
      transition: all 0.3s ease;
    }

    .youtube-placeholder:hover {
      background: linear-gradient(135deg, #333, #555);
    }

    .youtube-play-button-large {
      width: 100px;
      height: 70px;
      background: rgba(255, 255, 255, 0.9);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 48px;
      color: #ff0000;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .youtube-play-button-large:hover {
      background: white;
      transform: scale(1.1);
      box-shadow: 0 8px 25px rgba(255, 0, 0, 0.3);
    }

    /* Pulse animation for video preview */
    .youtube-placeholder::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 150px;
      height: 150px;
      border: 3px solid rgba(255, 255, 255, 0.3);
      border-radius: 50%;
      animation: pulse 2s infinite;
      z-index: 1;
    }

    @keyframes pulse {
      0% {
        transform: translate(-50%, -50%) scale(0.8);
        opacity: 1;
      }
      100% {
        transform: translate(-50%, -50%) scale(1.2);
        opacity: 0;
      }
    }

    .youtube-preview-container iframe {
      width: 100%;
      height: 100%;
    }

    /* Advertisement Banner Styles - Link-Viewer Design */
    .banner-container {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      width: 280px;
      z-index: 1000;
    }

    .banner-container.left {
      left: 20px;
    }

    .banner-container.right {
      right: 20px;
    }

    .banner-slot {
      background: white;
      border-radius: 15px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
      margin-bottom: 20px;
      overflow: hidden;
      height: 200px;
      position: relative;
      transition: all 0.3s ease;
    }

    .banner-slot:hover {
      transform: scale(1.02);
      box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }

    .banner-slot .banner-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      cursor: pointer;
      transition: opacity 0.5s ease;
    }

    .banner-slot .advertise-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      background: linear-gradient(45deg, #f8f9fa, #ffffff);
      border: 2px dashed #dee2e6;
      color: #6c757d;
      text-decoration: none;
      transition: all 0.3s ease;
      padding: 20px;
      text-align: center;
    }

    .banner-slot .advertise-placeholder:hover {
      background: linear-gradient(45deg, #e9ecef, #f8f9fa);
      color: #495057;
      border-color: #adb5bd;
      text-decoration: none;
    }

    .banner-toggle {
      position: absolute;
      top: 10px;
      background: rgba(0,0,0,0.7);
      color: white;
      border: none;
      border-radius: 20px;
      width: 35px;
      height: 35px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .banner-container.left .banner-toggle {
      right: -45px;
    }

    .banner-container.right .banner-toggle {
      left: -45px;
    }

    .banner-toggle:hover {
      background: rgba(102, 126, 234, 0.9);
    }

    .banner-container.hidden {
      opacity: 0;
      pointer-events: none;
    }

    .banner-container.left.hidden {
      transform: translate(-100%, -50%);
    }

    .banner-container.right.hidden {
      transform: translate(100%, -50%);
    }

    /* Mobile Banner Section */
    .mobile-banner-section {
      display: none;
      margin-top: 30px;
    }

    .mobile-banner-header {
      text-align: center;
      margin-bottom: 15px;
    }

    .mobile-banner-header h6 {
      color: #495057;
      font-weight: 600;
      margin: 0;
    }

    .mobile-banner-inline {
      background: white;
      border-radius: 15px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
      overflow: hidden;
      height: 140px;
      position: relative;
      transition: all 0.3s ease;
    }

    .mobile-banner-inline:hover {
      transform: scale(1.02);
      box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }

    .mobile-banner-inline .banner-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      cursor: pointer;
    }

    .mobile-banner-inline .advertise-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      background: linear-gradient(45deg, #f8f9fa, #ffffff);
      border: 2px dashed #dee2e6;
      color: #6c757d;
      text-decoration: none;
      transition: all 0.3s ease;
      padding: 20px;
      text-align: center;
    }

    .mobile-banner-inline .advertise-placeholder:hover {
      background: linear-gradient(45deg, #e9ecef, #f8f9fa);
      color: #495057;
      border-color: #adb5bd;
      text-decoration: none;
    }

    @media (min-width: 1201px) {
      .banner-container {
        display: block;
      }
      .mobile-banner-section {
        display: none;
      }
    }

    @media (max-width: 1200px) {
      .banner-container {
        display: none;
      }
      .mobile-banner-section {
        display: block;
      }
    }

    @media (max-width: 991px) {
      .mobile-banner-section {
        margin-top: 20px;
      }
      
      .mobile-banner-inline {
        height: 120px;
      }
    }
  </style>
</head>
<body class="bg-light">
  <%- include('../partials/navbar') %>

  <div class="container mt-4">
    <div class="row justify-content-center">
      <div class="col-lg-6 col-md-8 col-sm-10">
        <div class="card shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-4">
              <h2 class="card-title mb-0"><%= link.title %></h2>
              <a href="/" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Links
              </a>
            </div>
            
            <div class="row mb-4">
              <% if (link.type === 'youtube' && link.url) { %>
                <% 
                  // Extract YouTube video ID from URL
                  let videoId = '';
                  const youtubeUrl = link.url;
                  const regex = /(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/;
                  const match = youtubeUrl.match(regex);
                  if (match) {
                    videoId = match[1];
                  }
                %>
                <div class="col-12 mb-4">
                  <div class="card">
                    <div class="card-header">
                      <h5 class="mb-0">
                        <i class="fab fa-youtube text-danger me-2"></i>
                        Video Preview
                      </h5>
                    </div>
                    <div class="card-body p-0">
                      <% if (videoId) { %>
                        <div class="youtube-preview-container" 
                             style="position: relative; width: 100%; height: 400px; background: #000;"
                             data-video-id="<%= videoId %>"
                             data-video-title="<%= link.title %>">
                          <div class="youtube-placeholder d-flex flex-column align-items-center justify-content-center h-100 text-white" style="cursor: pointer;">
                            <div class="youtube-play-button-large mb-3">
                              <i class="fab fa-youtube"></i>
                            </div>
                            <h5 class="text-center px-3"><%= link.title %></h5>
                            <p class="text-center text-muted px-3">Click to load and watch the video</p>
                          </div>
                        </div>
                      <% } else { %>
                        <div class="d-flex flex-column align-items-center justify-content-center bg-dark text-white" style="height: 300px;">
                          <i class="fab fa-youtube fa-4x text-danger mb-3"></i>
                          <p class="mb-0">Unable to extract video ID</p>
                          <small class="text-muted">Original URL: <%= link.url %></small>
                        </div>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% } %>
              
              <% if (link.image_url && link.type !== 'youtube') { %>
                <div class="col-md-4">
                  <img src="<%= link.image_url %>" alt="<%= link.title %>" class="img-fluid rounded">
                </div>
              <% } %>
              <div class="<%= (link.image_url && link.type !== 'youtube') ? 'col-md-8' : 'col-12' %>">
                <p class="text-muted"><%= link.description %></p>
                <% if (link.type === 'product') { %>
                  <p class="h4 text-primary mb-3">$<%= parseFloat(link.price).toFixed(4) %></p>
                <% } %>
                <div class="d-flex align-items-center mb-3">
                  <span class="badge <%= 
                    link.type === 'product' ? 'bg-primary' : 
                    link.type === 'youtube' ? 'bg-danger' : 
                    'bg-info' %> me-2">
                    <%= link.type %>
                  </span>
                  <% if (link.category) { %>
                    <span class="badge bg-secondary"><%= link.category %></span>
                  <% } %>
                </div>
              </div>
            </div>

            <div class="card bg-light mb-4">
              <div class="card-body">
                <h5 class="card-title">Your Share Link</h5>
                <div class="input-group">
                  <input type="text" class="form-control" id="shareUrl" value="<%= shareUrl %>" readonly>
                  <button class="btn btn-outline-primary" type="button" id="copyBtn">
                    <i class="fas fa-copy"></i> Copy
                  </button>
                </div>
              </div>
            </div>

            <div class="d-flex justify-content-center gap-3">
              <button class="btn btn-outline-primary share-btn" data-platform="facebook">
                <i class="fab fa-facebook"></i> Facebook
              </button>
              <button class="btn btn-outline-info share-btn" data-platform="twitter">
                <i class="fab fa-twitter"></i> Twitter
              </button>
              <button class="btn btn-outline-success share-btn" data-platform="whatsapp">
                <i class="fab fa-whatsapp"></i> WhatsApp
              </button>
            </div>

            <div class="alert alert-info mt-4">
              <i class="fas fa-info-circle"></i> 
              Share this link to earn commission for every click! 
              The link will remain active until it reaches <%= link.click_target %> clicks.
            </div>

            <!-- Mobile Banner Section -->
            <div class="mobile-banner-section">
              <div class="mobile-banner-header">
                <h6><i class="fas fa-star text-warning me-1"></i>Sponsored Content</h6>
              </div>
              <div class="mobile-banner-inline" id="mobileBannerContainer">
                <!-- Mobile banners will be loaded here -->
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Desktop Banner Containers -->
  <div class="banner-container left" id="leftBanners">
    <button class="banner-toggle" onclick="toggleBanners('left')" title="Hide Ads">
      <i class="fas fa-eye-slash"></i>
    </button>
    <div class="banner-slot" data-position="1">
      <a href="#" class="advertise-placeholder">
        <i class="fas fa-bullhorn fa-2x mb-2"></i>
        <strong>Advertise Here</strong>
        <small>Reach our audience</small>
      </a>
    </div>
    <div class="banner-slot" data-position="2">
      <a href="#" class="advertise-placeholder">
        <i class="fas fa-bullhorn fa-2x mb-2"></i>
        <strong>Advertise Here</strong>
        <small>Reach our audience</small>
      </a>
    </div>
  </div>

  <div class="banner-container right" id="rightBanners">
    <button class="banner-toggle" onclick="toggleBanners('right')" title="Hide Ads">
      <i class="fas fa-eye-slash"></i>
    </button>
    <div class="banner-slot" data-position="3">
      <a href="#" class="advertise-placeholder">
        <i class="fas fa-bullhorn fa-2x mb-2"></i>
        <strong>Advertise Here</strong>
        <small>Reach our audience</small>
      </a>
    </div>
  </div>

  <%- include('../partials/footer') %>
  
  <!-- YouTube API Script -->
  <script src="https://www.youtube.com/iframe_api"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let youtubePlayer = null;
    let youtubeApiReady = false;

    // YouTube API ready callback
    function onYouTubeIframeAPIReady() {
      youtubeApiReady = true;
      console.log('YouTube API is ready');
    }

    // YouTube video loading functionality
    function loadYouTubeVideo(container, videoId, title) {
      // Show loading spinner
      container.innerHTML = `
        <div class="d-flex align-items-center justify-content-center h-100">
          <div class="spinner-border text-danger" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading video...</span>
          </div>
        </div>
      `;
      
      // Create iframe
      const iframe = document.createElement('iframe');
      iframe.width = '100%';
      iframe.height = '400';
      iframe.src = `https://www.youtube.com/embed/${videoId}?enablejsapi=1&modestbranding=1&rel=0&showinfo=0&autoplay=1`;
      iframe.title = title;
      iframe.frameBorder = '0';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      
      // Add unique ID for YouTube API
      iframe.id = `youtube-player-${videoId}`;
      
      // Add error handling
      iframe.onerror = function() {
        container.innerHTML = `
          <div class="d-flex flex-column align-items-center justify-content-center h-100 bg-dark text-white">
            <i class="fab fa-youtube fa-4x text-danger mb-3"></i>
            <p class="mb-0">Unable to load video</p>
            <small class="text-muted">${title}</small>
            <button class="btn btn-outline-light btn-sm mt-2" onclick="window.open('https://youtube.com/watch?v=${videoId}', '_blank')">
              Watch on YouTube
            </button>
          </div>
        `;
      };
      
      // Replace placeholder with iframe
      setTimeout(() => {
        container.innerHTML = '';
        container.appendChild(iframe);
        
        // Initialize YouTube player
        if (youtubeApiReady) {
          setTimeout(() => {
            try {
              initializeYouTubePlayer(iframe.id, videoId);
            } catch (error) {
              console.log('YouTube player initialization failed:', error);
            }
          }, 1000);
        }
      }, 500);
    }

    function initializeYouTubePlayer(playerId, videoId) {
      try {
        if (document.getElementById(playerId)) {
          youtubePlayer = new YT.Player(playerId, {
            events: {
              'onReady': function(event) {
                console.log('YouTube player ready:', playerId);
              },
              'onError': function(event) {
                console.log('YouTube player error:', event.data);
                const container = document.getElementById(playerId).parentElement;
                let errorMessage = 'Video unavailable';
                
                switch(event.data) {
                  case 2:
                    errorMessage = 'Invalid video ID';
                    break;
                  case 5:
                    errorMessage = 'Video not supported in HTML5';
                    break;
                  case 100:
                    errorMessage = 'Video not found';
                    break;
                  case 101:
                  case 150:
                    errorMessage = 'Video not allowed to be embedded';
                    break;
                }
                
                container.innerHTML = `
                  <div class="d-flex flex-column align-items-center justify-content-center bg-dark text-white h-100">
                    <i class="fab fa-youtube fa-4x text-danger mb-3"></i>
                    <p class="mb-0">${errorMessage}</p>
                    <small class="text-muted">Video ID: ${videoId}</small>
                    <button class="btn btn-outline-light btn-sm mt-2" onclick="window.open('https://youtube.com/watch?v=${videoId}', '_blank')">
                      Watch on YouTube
                    </button>
                  </div>
                `;
              }
            }
          });
        }
      } catch (error) {
        console.error('Error creating YouTube player:', error);
      }
    }

    // Initialize YouTube video preview click handler
    document.addEventListener('DOMContentLoaded', function() {
      const youtubeContainer = document.querySelector('.youtube-preview-container');
      if (youtubeContainer) {
        youtubeContainer.addEventListener('click', function() {
          const videoId = this.dataset.videoId;
          const videoTitle = this.dataset.videoTitle;
          
          if (videoId) {
            loadYouTubeVideo(this, videoId, videoTitle);
          }
        });
      }
    });

    // Copy to clipboard functionality
    document.getElementById('copyBtn').addEventListener('click', function() {
      const shareUrl = document.getElementById('shareUrl');
      shareUrl.select();
      shareUrl.setSelectionRange(0, 99999);
      navigator.clipboard.writeText(shareUrl.value);
      
      const originalText = this.innerHTML;
      this.innerHTML = '<i class="fas fa-check"></i> Copied!';
      setTimeout(() => {
        this.innerHTML = originalText;
      }, 2000);
    });

    // Social sharing functionality
    document.querySelectorAll('.share-btn').forEach(button => {
      button.addEventListener('click', () => {
        const platform = button.dataset.platform;
        const url = encodeURIComponent('<%= shareUrl %>');
        const title = encodeURIComponent('<%= link.title %>');
        let shareUrl = '';

        switch(platform) {
          case 'facebook':
            shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
            break;
          case 'twitter':
            shareUrl = `https://twitter.com/intent/tweet?url=${url}&text=${title}`;
            break;
          case 'whatsapp':
            shareUrl = `https://wa.me/?text=${title}%20${url}`;
            break;
        }

        window.open(shareUrl, '_blank', 'width=600,height=400');
      });
    });

    // Banner tracking and interaction functions
    function handleBannerClick(bannerId, targetUrl, linkId) {
      // Track the click
      fetch('/api/banner/click', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          bannerId: bannerId,
          targetUrl: targetUrl,
          linkId: linkId
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success && data.targetUrl) {
          // Open the target URL in a new tab
          window.open(data.targetUrl, '_blank');
        }
      })
      .catch(error => {
        console.error('Banner click tracking error:', error);
        // Still open the URL even if tracking fails
        window.open(targetUrl, '_blank');
      });
    }

    // Advanced Banner Management System - Link Viewer Design
    let bannerData = [];
    let desktopBannerIndex = 0;
    let mobileBannerIndex = 0;
    let desktopRotationInterval = null;
    let mobileRotationInterval = null;
    let bannersHidden = { left: false, right: false };

    function initializeBanners() {
      try {
        bannerData = <%- JSON.stringify(banners || []) %>;
        console.log('Initializing banners:', bannerData.length);
        
        if (bannerData && bannerData.length > 0) {
          displayBannersOnDesktop();
          displayBannersOnMobile();
          startRotations();
          trackBannerImpressions();
        } else {
          displayPlaceholderBanners();
        }
      } catch (error) {
        console.error('Banner initialization error:', error);
        displayPlaceholderBanners();
      }
    }

    function displayBannersOnDesktop() {
      const leftContainer = document.getElementById('leftBanners');
      const rightContainer = document.getElementById('rightBanners');
      
      if (!leftContainer || !rightContainer || !bannerData || bannerData.length === 0) return;

      // Define the 3 desktop slots: 2 left, 1 right
      const leftSlots = leftContainer.querySelectorAll('.banner-slot');
      const rightSlots = rightContainer.querySelectorAll('.banner-slot');
      
      // Fill left slots (positions 1-2)
      leftSlots.forEach((slot, index) => {
        if (bannerData.length > 3) {
          // Use rotation index when we have more than 3 ads
          const bannerIndex = (desktopBannerIndex + index) % bannerData.length;
          const banner = bannerData[bannerIndex];
          slot.innerHTML = `
            <img src="${banner.image_url}" 
                 alt="${banner.title}" 
                 class="banner-image" 
                 onclick="handleBannerClick('${banner.id}', '${banner.click_url}', '<%= link.id %>')"
                 loading="lazy">
          `;
        } else if (bannerData[index]) {
          // Show real ad if available (for 3 or fewer ads)
          const banner = bannerData[index];
          slot.innerHTML = `
            <img src="${banner.image_url}" 
                 alt="${banner.title}" 
                 class="banner-image" 
                 onclick="handleBannerClick('${banner.id}', '${banner.click_url}', '<%= link.id %>')"
                 loading="lazy">
          `;
        } else {
          // Show "Advertise Here" placeholder if no ad available
          slot.innerHTML = `
            <a href="https://wa.me/0783987223?text=Hello%20admin%20of%20benixspace%20i%20want%20to%20advertise%20on%20your%20platform" 
               target="_blank" 
               class="advertise-placeholder">
              <i class="fas fa-bullhorn fa-2x mb-2"></i>
              <strong>Advertise Here</strong>
              <small>Reach our audience</small>
            </a>
          `;
        }
      });

      // Fill right slot (position 3)
      rightSlots.forEach((slot, index) => {
        if (bannerData.length > 3) {
          // Use rotation index when we have more than 3 ads
          const bannerIndex = (desktopBannerIndex + index + 2) % bannerData.length; // Right side starts from 3rd position
          const banner = bannerData[bannerIndex];
          slot.innerHTML = `
            <img src="${banner.image_url}" 
                 alt="${banner.title}" 
                 class="banner-image" 
                 onclick="handleBannerClick('${banner.id}', '${banner.click_url}', '<%= link.id %>')"
                 loading="lazy">
          `;
        } else {
          const bannerIndex = index + 2; // Right side starts from 3rd banner (for 3 or fewer ads)
          if (bannerData[bannerIndex]) {
            // Show real ad if available
            const banner = bannerData[bannerIndex];
            slot.innerHTML = `
              <img src="${banner.image_url}" 
                   alt="${banner.title}" 
                   class="banner-image" 
                   onclick="handleBannerClick('${banner.id}', '${banner.click_url}', '<%= link.id %>')"
                   loading="lazy">
            `;
          } else {
            // Show "Advertise Here" placeholder if no ad available
            slot.innerHTML = `
              <a href="https://wa.me/0783987223?text=Hello%20admin%20of%20benixspace%20i%20want%20to%20advertise%20on%20your%20platform" 
                 target="_blank" 
                 class="advertise-placeholder">
                <i class="fas fa-bullhorn fa-2x mb-2"></i>
                <strong>Advertise Here</strong>
                <small>Reach our audience</small>
              </a>
            `;
          }
        }
      });
    }

    function displayBannersOnMobile() {
      const mobileContainer = document.getElementById('mobileBannerContainer');
      if (!mobileContainer || !bannerData || bannerData.length === 0) return;

      const banner = bannerData[mobileBannerIndex % bannerData.length];
      
      mobileContainer.innerHTML = `
        <img src="${banner.image_url}" 
             alt="${banner.title}" 
             class="banner-image" 
             onclick="handleBannerClick('${banner.id}', '${banner.click_url}', '<%= link.id %>')"
             loading="lazy">
      `;
    }

    function displayPlaceholderBanners() {
      // Desktop placeholders - only 3 slots total
      const leftContainer = document.getElementById('leftBanners');
      const rightContainer = document.getElementById('rightBanners');
      
      if (leftContainer) {
        const leftSlots = leftContainer.querySelectorAll('.banner-slot');
        leftSlots.forEach(slot => {
          slot.innerHTML = `
            <a href="https://wa.me/0783987223?text=Hello%20admin%20of%20benixspace%20i%20want%20to%20advertise%20on%20your%20platform" 
               target="_blank" 
               class="advertise-placeholder">
              <i class="fas fa-bullhorn fa-2x mb-2"></i>
              <strong>Advertise Here</strong>
              <small>Reach our audience</small>
            </a>
          `;
        });
      }

      if (rightContainer) {
        const rightSlots = rightContainer.querySelectorAll('.banner-slot');
        rightSlots.forEach(slot => {
          slot.innerHTML = `
            <a href="https://wa.me/0783987223?text=Hello%20admin%20of%20benixspace%20i%20want%20to%20advertise%20on%20your%20platform" 
               target="_blank" 
               class="advertise-placeholder">
              <i class="fas fa-bullhorn fa-2x mb-2"></i>
              <strong>Advertise Here</strong>
              <small>Reach our audience</small>
            </a>
          `;
        });
      }

      // Mobile placeholder
      const mobileContainer = document.getElementById('mobileBannerContainer');
      if (mobileContainer) {
        mobileContainer.innerHTML = `
          <a href="https://wa.me/0783987223?text=Hello%20admin%20of%20benixspace%20i%20want%20to%20advertise%20on%20your%20platform" 
             target="_blank" 
             class="advertise-placeholder">
            <i class="fas fa-bullhorn fa-2x mb-2"></i>
            <strong>Advertise Here</strong>
            <small>Reach our audience</small>
          </a>
        `;
      }
    }

    function startRotations() {
      if (!bannerData || bannerData.length <= 3) return; // No rotation needed for 3 or fewer ads

      // Desktop rotation (8 seconds) - only rotate when we have more than 3 ads
      desktopRotationInterval = setInterval(() => {
        desktopBannerIndex = (desktopBannerIndex + 1) % bannerData.length;
        displayBannersOnDesktop();
      }, 8000);

      // Mobile rotation (6 seconds, only if more than 1 banner)
      if (bannerData.length > 1) {
        mobileRotationInterval = setInterval(() => {
          mobileBannerIndex = (mobileBannerIndex + 1) % bannerData.length;
          displayBannersOnMobile();
        }, 6000);
      }
    }

    function stopRotations() {
      if (desktopRotationInterval) {
        clearInterval(desktopRotationInterval);
        desktopRotationInterval = null;
      }
      if (mobileRotationInterval) {
        clearInterval(mobileRotationInterval);
        mobileRotationInterval = null;
      }
    }

    function toggleBanners(side) {
      const container = document.getElementById(side + 'Banners');
      const toggle = container.querySelector('.banner-toggle');
      
      if (bannersHidden[side]) {
        container.classList.remove('hidden');
        toggle.innerHTML = '<i class="fas fa-eye-slash"></i>';
        toggle.title = 'Hide Ads';
        bannersHidden[side] = false;
      } else {
        container.classList.add('hidden');
        toggle.innerHTML = '<i class="fas fa-eye"></i>';
        toggle.title = 'Show Ads';
        bannersHidden[side] = true;
      }
    }

    // Track banner impressions when banners are visible
    function trackBannerImpressions() {
      if (!bannerData || bannerData.length === 0) return;
      
      const linkId = '<%= link.id %>';
      
      bannerData.forEach(banner => {
        fetch('/api/banner/track', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            bannerId: banner.id,
            eventType: 'impression',
            linkId: linkId
          })
        })
        .catch(error => console.error('Banner impression tracking error:', error));
      });
    }

    // Handle window resize to refresh banner display and rotation
    window.addEventListener('resize', function() {
      // Stop current rotations
      stopRotations();
      
      // Reset banner indices
      desktopBannerIndex = 0;
      mobileBannerIndex = 0;
      
      // Redisplay banners based on new screen size
      if (bannerData && bannerData.length > 0) {
        displayBannersOnDesktop();
        displayBannersOnMobile();
        // Restart rotations with appropriate settings
        startRotations();
      } else {
        displayPlaceholderBanners();
      }
    });

    // Initialize banners when page loads
    document.addEventListener('DOMContentLoaded', function() {
      setTimeout(initializeBanners, 1000);
    });

    // Cleanup when page unloads
    window.addEventListener('beforeunload', stopRotations);
  </script>
</body>
</html>